{
  "name": "@blackasteroid/kuma-cli",
  "version": "1.7.0",
  "description": "CLI for managing Uptime Kuma via Socket.IO API",
  "keywords": [
    "cli",
    "monitoring",
    "uptime-kuma"
  ],
  "license": "MIT",
  "author": "Pablo Morales",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pablofmorales/kuma-cli.git"
  },
  "bin": {
    "kuma": "dist/index.mjs"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "typecheck": "vp check --no-fmt --no-lint",
    "prepublishOnly": "npm run build",
    "test": "vp test run",
    "test:watch": "vp test",
    "lint": "vp lint",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#dist\"",
    "fix": "vp check --fix",
    "fmt": "vp fmt",
    "format": "vp fmt --check",
    "check": "vp check",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "enquirer": "^2.4.1",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.1",
    "react": "^19.2.4",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "markdownlint-cli2": "^0.23.0",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "vite-plus": "0.2.2"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "11.18.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
