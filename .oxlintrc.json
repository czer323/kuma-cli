{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "vitest"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-unused-vars": "off",
    "no-useless-escape": "off",
    "vitest/require-mock-type-parameters": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["dist/", "node_modules/"]
}
